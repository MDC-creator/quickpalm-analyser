# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real secrets.

# Required. Grafana admin login password (user: admin). Compose refuses to
# start without this set — do not use the old "quickpalm" default in prod.
GRAFANA_ADMIN_PASSWORD=changeme

# Optional. If set, the /chat endpoint requires this value in the
# X-API-Key header. Leave empty only if the stack is not reachable
# from an untrusted network.
CHAT_API_KEY=

# Optional. Slack incoming webhook URL for anomaly/disk-forecast alerts.
SLACK_WEBHOOK_URL=

# Optional. Ollama model used by the chat service.
OLLAMA_MODEL=llama3.2:1b
